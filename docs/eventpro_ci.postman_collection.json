{
  "info": {
    "name": "EVENTPRO CI - API",
    "description": "Collection des endpoints REST d'EVENTPRO CI (JWT). Lancez d'abord 'Auth / Connexion (token)' : le token d'acces est stocke automatiquement dans la variable {{access_token}} et reutilise par les requetes protegees.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Inscription (register)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/register/", "host": ["{{baseUrl}}"], "path": ["api", "register", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"nouveau_participant\",\n  \"email\": \"nouveau@eventpro.ci\",\n  \"password\": \"Test@2025\",\n  \"role\": \"PARTICIPANT\"\n}"
            }
          }
        },
        {
          "name": "Connexion (token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var data = pm.response.json();",
                  "if (data.access) { pm.collectionVariables.set('access_token', data.access); }",
                  "if (data.refresh) { pm.collectionVariables.set('refresh_token', data.refresh); }",
                  "pm.test('Token recu', function () { pm.expect(data.access).to.be.a('string'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/token/", "host": ["{{baseUrl}}"], "path": ["api", "token", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"organisateur1\",\n  \"password\": \"Orga@2025\"\n}"
            }
          }
        },
        {
          "name": "Rafraichir le token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/token/refresh/", "host": ["{{baseUrl}}"], "path": ["api", "token", "refresh", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Evenements",
      "item": [
        {
          "name": "Liste des evenements",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/events/", "host": ["{{baseUrl}}"], "path": ["api", "events", ""] }
          }
        },
        {
          "name": "Creer un evenement (organisateur)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/events/", "host": ["{{baseUrl}}"], "path": ["api", "events", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Concert de demonstration\",\n  \"description\": \"Cree via l'API\",\n  \"category\": \"CONCERT\",\n  \"date\": \"2026-12-01T20:00:00Z\",\n  \"end_date\": \"2026-12-01T23:00:00Z\",\n  \"location\": \"Abidjan\",\n  \"max_capacity\": 200,\n  \"status\": \"PUBLISHED\"\n}"
            }
          }
        },
        {
          "name": "Detail d'un evenement",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/events/1/", "host": ["{{baseUrl}}"], "path": ["api", "events", "1", ""] }
          }
        }
      ]
    },
    {
      "name": "Billetterie",
      "item": [
        {
          "name": "Creer un type de billet (organisateur)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/tickets/types/", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "types", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": 1,\n  \"name\": \"VIP\",\n  \"price\": 20000,\n  \"quota\": 100\n}"
            }
          }
        },
        {
          "name": "Reserver un billet (participant)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/tickets/book/", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "book", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticket_type_id\": 1\n}"
            }
          }
        },
        {
          "name": "Annuler une reservation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/tickets/cancel/1/", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "cancel", "1", ""] }
          }
        },
        {
          "name": "Tableau de bord organisateur",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{baseUrl}}/api/tickets/dashboard/", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "dashboard", ""] }
          }
        }
      ]
    }
  ]
}
